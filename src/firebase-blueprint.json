{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user fitness goals and physical data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "weight": { "type": "number", "description": "Weight in kg" },
        "height": { "type": "number", "description": "Height in cm" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "activityLevel": { "type": "string", "enum": ["sedentary", "light", "moderate", "active", "very_active"] },
        "goal": { "type": "string", "enum": ["lose_weight", "maintain", "gain_muscle"] },
        "dailyCalorieTarget": { "type": "number" },
        "onboardingCompleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "MealLog": {
      "title": "Meal Log",
      "description": "Stores scanned or manually entered meal data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "fat": { "type": "number" },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "calories", "timestamp"]
    },
    "WorkoutLog": {
      "title": "Workout Log",
      "description": "Stores completed exercises.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "exerciseName": { "type": "string" },
        "sets": { "type": "number" },
        "reps": { "type": "number" },
        "weight": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "exerciseName", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data"
    },
    "/meals/{mealId}": {
      "schema": "MealLog",
      "description": "Individual meal logs"
    },
    "/workouts/{workoutId}": {
      "schema": "WorkoutLog",
      "description": "Individual workout logs"
    }
  }
}
